{
    "name": "@smooai/deploy",
    "version": "0.1.4",
    "description": "Shared SmooAI deploy primitives — reusable SST v4 constructs (API Gateway WebSocket + Rust Lambda + DynamoDB single-table + S3 blob bucket + S3 Vectors placeholder). Consumed by smooth-operator and dogfooded by smooai.",
    "license": "MIT",
    "type": "module",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./components/smooth-agent-api": "./src/components/smooth-agent-api.ts",
        "./components/websocket-lambda-api": "./src/components/websocket-lambda-api.ts",
        "./components/dynamo-single-table": "./src/components/dynamo-single-table.ts",
        "./components/smooai-next-edge": "./src/components/smooai-next-edge.ts",
        "./next": {
            "types": "./src/next/index.ts",
            "import": "./src/next/index.ts",
            "default": "./src/next/index.ts"
        },
        "./next/cache-handler.cjs": "./src/next/cache-handler.cjs"
    },
    "files": [
        "src"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "@aws-sdk/client-s3": ">=3",
        "sst": ">=4.13.0 <5"
    },
    "peerDependenciesMeta": {
        "@aws-sdk/client-s3": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/node": "22.10.5",
        "sst": "4.13.0",
        "typescript": "5.7.3"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/SmooAI/deploy.git",
        "directory": "sst"
    },
    "publishConfig": {
        "access": "public"
    }
}
