{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2023"],
        "types": ["node"],
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "declaration": false,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": false
    },
    "include": ["src/**/*.ts", ".sst/platform/config.d.ts"],
    "exclude": ["node_modules", ".sst/platform/src"]
}
